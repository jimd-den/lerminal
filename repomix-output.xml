  3: export class OpenRouterAgentGateway implements AgentGateway {
  4:   async ask(
  5:     query: string,
  6:     contextCards: Card[],
  7:     apiKey: string,
  8:     model: string,
  9:     systemPrompt?: string
 10:   ): Promise<AgentCardResponse[]> {
 11:     const logTimestamp = new Date().toISOString();
 12:     const modelToUse = model || "google/gemini-2.5-flash";
 13:     const keyPrefix = apiKey ? `${apiKey.substring(0, 10)}... (len: ${apiKey.length})` : "EMPTY";
 14:     console.log(`[${logTimestamp}] [OpenRouterAgentGateway.ask] query="${query}" | contextCardsCount=${contextCards.length} | model="${modelToUse}" | apiKey="${keyPrefix}"`);
 15:     if (!apiKey) {
 16:       console.warn(`[${logTimestamp}] [OpenRouterAgentGateway] API Key is missing. Falling back to local generation.`);
 17:       return this.generateLocalFallback(query);
 18:     }
 19:     const contextText = contextCards
 20:       .map(card => `[Card Title: ${card.title}]\n${card.body}`)
 21:       .join("\n\n")
 22:       .substring(0, 3000);
 23:     const defaultSystemPrompt = `You generate atomic learning cards. Respond ONLY with a valid JSON array of objects (no prose, no markdown code block formatting). Each object must have:
 24: - "title": string (max 6 words, representing the atomic concept)
 25: - "body": string (1-2 clear, simple sentences explaining the concept)
 26: Each card must be a distinct, recall-ready idea.`;
 27:     const activeSystemPrompt = systemPrompt || defaultSystemPrompt;
 28:     const prompt = `${activeSystemPrompt}
 29: ${contextText ? `Use this source context to extract and base your facts on:\n${contextText}\n\n` : ""}Query: ${query}`;
 30:     try {
 31:       const response = await fetch("https:
 32:         method: "POST",
 33:         headers: {
 34:           "Content-Type": "application/json",
 35:           "Authorization": `Bearer ${apiKey}`,
 36:           "HTTP-Referer": "https://github.com/dbslim/lerminal",
 37:           "X-Title": "Learnimal",
 38:         },
 39:         body: JSON.stringify({
 40:           model: modelToUse,
 41:           messages: [
 42:             {
 43:               role: "user",
 44:               content: prompt,
 45:             },
 46:           ],
 47:         }),
 48:       });
 49:       if (!response.ok) {
 50:         let errMsg = `HTTP error: ${response.status} ${response.statusText}`;
 51:         try {
 52:           const errData = await response.json();
 53:           if (errData && errData.error && errData.error.message) {
 54:             errMsg += ` - ${errData.error.message}`;
 55:           }
 56:         } catch (e) {
 57:           try {
 58:             const text = await response.text();
 59:             if (text) errMsg += ` - ${text.substring(0, 150)}`;
 60:           } catch (_) {}
 61:         }
 62:         throw new Error(errMsg);
 63:       }
 64:       const data = await response.json();
 65:       const content = data.choices?.[0]?.message?.content?.trim() || "[]";
 66:       const cleanJson = content
 67:         .replace(/^```json/i, "")
 68:         .replace(/^```/, "")
 69:         .replace(/```$/, "")
 70:         .trim();
 71:       const parsed = JSON.parse(cleanJson);
 72:       if (!Array.isArray(parsed)) {
 73:         throw new Error("Response is not a valid JSON array");
 74:       }
 75:       const cards: AgentCardResponse[] = parsed.map((item: any) => ({
 76:         title: String(item.title || "Concept").substring(0, 100),
 77:         body: String(item.body || "").substring(0, 1000),
 78:       }));
 79:       console.log(`[${logTimestamp}] [OpenRouterAgentGateway] OpenRouter SUCCESS: model=${modelToUse} | generated ${cards.length} cards`);
 80:       return cards;
 81:     } catch (err: any) {
 82:       console.error(`[${logTimestamp}] [OpenRouterAgentGateway] request failed: ${err.message}. Falling back to local generation.`);
 83:       return this.generateLocalFallback(query);
 84:     }
 85:   }
 86:   async fetchModels(): Promise<AgentModel[]> {
 87:     const logTimestamp = new Date().toISOString();
 88:     console.log(`[${logTimestamp}] [OpenRouterAgentGateway.fetchModels] Fetching models from OpenRouter...`);
 89:     try {
 90:       const response = await fetch("https:
 91:       if (!response.ok) {
 92:         let errMsg = `HTTP error: ${response.status} ${response.statusText}`;
 93:         try {
 94:           const errData = await response.json();
 95:           if (errData && errData.error && errData.error.message) {
 96:             errMsg += ` - ${errData.error.message}`;
 97:           }
 98:         } catch (e) {
 99:           try {
100:             const text = await response.text();
101:             if (text) errMsg += ` - ${text.substring(0, 150)}`;
102:           } catch (_) {}
103:         }
104:         throw new Error(errMsg);
105:       }
106:       const json = await response.json();
107:       if (!json || !Array.isArray(json.data)) {
108:         throw new Error("Invalid response format");
109:       }
110:       const models: AgentModel[] = json.data.map((m: any) => {
111:         const isFree = m.id.endsWith(":free") ||
112:           (m.pricing && parseFloat(m.pricing.prompt) === 0 && parseFloat(m.pricing.completion) === 0);
113:         return {
114:           id: m.id,
115:           name: m.name || m.id,
116:           free: isFree,
117:         };
118:       });
119:       console.log(`[${logTimestamp}] [OpenRouterAgentGateway.fetchModels] Retrieved ${models.length} models dynamically`);
120:       return models;
121:     } catch (err: any) {
122:       console.error(`[${logTimestamp}] [OpenRouterAgentGateway.fetchModels] Error: ${err.message}. Falling back to default list.`);
123:       return [
124:         { id: "google/gemini-2.5-flash:free", name: "Gemini 2.5 Flash (Free)", free: true },
125:         { id: "meta-llama/llama-3.1-8b-instruct:free", name: "Llama 3.1 8B (Free)", free: true },
126:         { id: "qwen/qwen-2.5-72b-instruct:free", name: "Qwen 2.5 72B (Free)", free: true },
127:         { id: "openchat/openchat-7b:free", name: "OpenChat 7B (Free)", free: true },
128:         { id: "google/gemini-2.5-flash", name: "Gemini 2.5 Flash", free: false },
129:         { id: "google/gemini-2.5-pro", name: "Gemini 2.5 Pro", free: false },
130:         { id: "meta-llama/llama-3.1-405b-instruct", name: "Llama 3.1 405B", free: false },
131:         { id: "anthropic/claude-3.5-sonnet", name: "Claude 3.5 Sonnet", free: false },
132:       ];
133:     }
134:   }
135:   private generateLocalFallback(query: string): AgentCardResponse[] {
136:     const topic = query
137:       .replace(/^(how|what|why|explain|tell me about|the)\s+/i, "")
138:       .replace(/\?$/, "")
139:       .trim();
140:     const capitalizedTopic = topic.charAt(0).toUpperCase() + topic.slice(1);
141:     return [
142:       {
143:         title: "Core idea",
144:         body: `At its heart, ${topic} is best understood as one central principle — name it in a single sentence before adding any detail.`,
145:       },
146:       {
147:         title: "Why it matters",
148:         body: `${capitalizedTopic} matters because it changes what you can predict or do; tie it to a concrete outcome you care about.`,
149:       },
150:       {
151:         title: "How it works",
152:         body: `Break ${topic} into the two or three moving parts that interact, and describe what each one does on its own.`,
153:       },
154:       {
155:         title: "Common mistake",
156:         body: `The usual error with ${topic} is to confuse it with a surface-similar idea — note the one distinction that keeps them apart.`,
157:       },
158:     ];
159:   }
160: }
