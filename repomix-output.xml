 6: import { CommandContext, CommandResult, PipelineCommand } from "./Command";
 7: export class CustomAgentCommand implements PipelineCommand {
 8:   readonly name: string;
 9:   constructor(
10:     private readonly definition: AgentCommandDefinition,
11:     private readonly agentGateway: AgentGateway,
12:     private readonly cardRepo: CardRepository
13:   ) {
14:     this.name = definition.name;
15:   }
16:   async execute(arg: string, ctx: CommandContext): Promise<CommandResult> {
17:     if (!arg) {
18:       return { kind: "needsInput", mode: "ask" };
19:     }
20:     let agentCards;
21:     try {
22:       agentCards = await this.agentGateway.ask(
23:         arg,
24:         ctx.inputCards,
25:         ctx.apiKey,
26:         ctx.model,
27:         this.definition.systemPrompt
28:       );
29:     } catch (err: any) {
30:       throw new AgentRequestError(err?.message);
31:     }
32:     const cards = agentCards.map(item =>
33:       createCard({
34:         workspaceId: ctx.workspaceId,
35:         type: "chunk",
36:         title: item.title,
37:         body: item.body,
38:         cite: arg.substring(0, 16),
39:         parentId: ctx.parentId ?? undefined,
40:       })
41:     );
42:     await this.cardRepo.saveCards(cards);
43:     return { kind: "cards", cards };
44:   }
45: }
