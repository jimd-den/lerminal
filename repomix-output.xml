667: function endReview(){
668:   $('#revQ').textContent='Done.';$('#revA').style.display='none';
669:   $('#revFoot').innerHTML=`<button class="yes" onclick="document.getElementById('review').classList.remove('show');render()">Back to canvas</button>`;
