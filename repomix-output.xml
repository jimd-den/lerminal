390: /* ---------- helpers ---------- */
391: const $ = s => document.querySelector(s);
392: const wsCards = () => S.cards.filter(c => c.ws === S.activeWs);
393: const dueCards = () => wsCards().filter(c => c.schedule && c.schedule.due <= now());
394: function toast(msg){const t=$('#toast');t.innerHTML=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2200);}
395: function md(t){return (t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/\*\*(.+?)\*\*/g,'<b>$1</b>').replace(/\n/g,'<br>');}
396: /* ---------- render canvas ---------- */
397: function render(){
398:   const wrap = $('#canvas');
399:   $('#wsName').textContent = S.workspaces.find(w=>w.id===S.activeWs)?.name || 'Workspace';
400:   const cards = wsCards();
401:   let html = '';
402:   const due = dueCards().length;
403:   if(due) html += `<div class="due-banner"><span class="dl">${due} card${due>1?'s':''} ready to review</span><button onclick="startReview()">Review</button></div>`;
404:   if(!cards.length){
405:     html += `<div class="empty"><h3>Empty canvas</h3><p>Open the drawer on the right and run <span class="mono">ask</span> — or pipe <span class="mono">ask | chunk | recall | space</span> to learn something end to end.</p></div>`;
406:   } else {
407:     cards.slice().reverse().forEach((c,i)=>{
408:       const sel = S.selection.has(c.id);
409:       const sched = c.schedule;
410:       let meta = '';
411:       if(sched){const d=Math.max(0,Math.round((sched.due-now())/DAY));meta=`<span class="due-pill">due ${d===0?'now':'in '+d+'d'}</span>`;}
412:       html += `<div class="card t-${c.type}${sel?' sel':''}${sched?' scheduled':''}" style="animation-delay:${Math.min(i*22,180)}ms">
413:         <div class="spine"></div>
414:         <div class="card-top">
415:           <span class="ctype">${c.type}${sched?' · spaced':''}</span>
416:           <button class="sel-dot${sel?' on':''}" onclick="toggleSel('${c.id}',event)" aria-label="Select">
417:             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L20 6"/></svg>
418:           </button>
419:         </div>
420:         <div onclick="openCard('${c.id}')">
421:           <div class="ctitle">${md(c.title)}</div>
422:           ${c.type==='question'?'':`<div class="cprev">${md(c.body)}</div>`}
423:           ${meta?`<div class="cmeta">${meta}</div>`:''}
424:         </div>
425:       </div>`;
426:     });
427:   }
428:   wrap.innerHTML = html;
429:   // selection bar
430:   const n = S.selection.size;
431:   $('#selCount').textContent = n;
432:   $('#selbar').classList.toggle('show', n>0);
433: }
434: /* ---------- selection ---------- */
435: window.toggleSel = (id,e)=>{e&&e.stopPropagation();
436:   S.selection.has(id)?S.selection.delete(id):S.selection.add(id);render();};
437: $('#selClear').onclick = ()=>{S.selection.clear();render();};
438: $('#selRun').onclick = ()=>openModal();
439: /* ---------- card detail ---------- */
440: window.openCard = (id)=>{
441:   const c = S.cards.find(x=>x.id===id); if(!c) return; S.openCard=id;
442:   $('#fcType').textContent = c.type.toUpperCase() + (c.schedule?' · SPACED':'');
443:   $('#fcType').style.color = `var(--c-${c.type})`;
444:   const body = $('#fcBody');
445:   if(c.type==='question'){
446:     body.innerHTML = `<div class="fc-title">${md(c.title)}</div>
447:       <div class="veil" id="veil"><div class="vt">Answer hidden</div><div class="vs">Recall it, then tap to reveal</div></div>`;
448:     $('#veil').onclick = ()=>{ $('#veil').outerHTML = `<div class="fc-answer">${md(c.answer)} ${c.cite?`<span class="cite">◆ ${c.cite}</span>`:''}</div>`; };
449:   } else {
450:     body.innerHTML = `<div class="fc-title">${md(c.title)}</div><div class="fc-text">${md(c.body)} ${c.cite?`<span class="cite">◆ ${c.cite}</span>`:''}</div>`;
451:   }
452:   // footer pipe actions
453:   const next = c.type==='source'?'chunk':c.type==='chunk'?'recall':c.type==='question'?'space':null;
454:   let foot = `<button onclick="closeFull()">Close</button>`;
455:   if(next) foot += `<button class="pipe" onclick="pipeFromCard('${id}','${next}')">Pipe → ${next}</button>`;
456:   $('#fcFoot').innerHTML = foot;
457:   $('#fullcard').classList.add('show');
458: };
459: window.closeFull = ()=>{$('#fullcard').classList.remove('show');S.openCard=null;};
460: $('#fcClose').onclick = closeFull;
461: window.pipeFromCard = (id,cmd)=>{closeFull();setTimeout(()=>runCommand(cmd,[id]),250);};
462: /* ---------- modal ---------- */
463: function openModal(){
464:   buildModal();
465:   $('#scrim').classList.add('show'); $('#modal').classList.add('show');
466:   const n=S.selection.size;
467:   $('#modalSub').innerHTML = n? `<b>${n}</b> card${n>1?'s':''} as input · stdin` : 'No cards selected · runs fresh';
468: }
469: function closeModal(){$('#scrim').classList.remove('show');$('#modal').classList.remove('show');$('#wsSheet').classList.remove('show');$('#setSheet').classList.remove('show');$('#inputSheet').classList.remove('show');S.pinEdit=false;}
470: $('#drawerHandle').onclick = openModal;
471: $('#scrim').onclick = closeModal;
472: function buildModal(){
473:   const body = $('#modalBody');
474:   let html = `<div class="grouplab">Easy access <span class="edit" onclick="togglePinEdit()">${S.pinEdit?'Done':'Edit'}</span></div><div class="cmd-pins">`;
475:   S.pinned.forEach(name=>{
476:     const c=COMMANDS[name]; if(!c) return;
477:     html += `<button class="cmd-chip" onclick="${S.pinEdit?`unpin('${name}')`:`runFromModal('${name}')`}">
478:       <span class="cd" style="background:${c.dot}"></span><span class="cn mono">${name}</span>${S.pinEdit?' ✕':''}</button>`;
479:   });
480:   html += `</div>`;
481:   html += `<div class="grouplab">All commands</div>`;
482:   Object.keys(COMMANDS).forEach(name=>{
483:     const c=COMMANDS[name]; const pinned=S.pinned.includes(name);
484:     html += `<div class="cmd-row" onclick="runFromModal('${name}')">
485:       <span class="cd" style="background:${c.dot}"></span>
486:       <div class="ci"><div class="cname mono">${name}</div><div class="cdesc">${c.desc}</div></div>
487:       <button class="pinstar ${pinned?'on':''}" onclick="togglePin('${name}',event)" aria-label="Pin">
488:         <svg viewBox="0 0 24 24" fill="${pinned?'currentColor':'none'}" stroke="currentColor" stroke-width="1.6"><path d="M12 2l3 7h7l-5.5 4 2 7L12 17l-6.5 5 2-7L2 9h7z"/></svg>
489:       </button></div>`;
490:   });
491:   body.innerHTML = html;
492: }
493: window.togglePinEdit = ()=>{S.pinEdit=!S.pinEdit;buildModal();};
494: window.unpin = (n)=>{S.pinned=S.pinned.filter(x=>x!==n);buildModal();toast(`Unpinned ${n}`);};
495: window.togglePin = (n,e)=>{e.stopPropagation(); S.pinned.includes(n)?S.pinned=S.pinned.filter(x=>x!==n):S.pinned.push(n); buildModal();};
496: window.runFromModal = (name)=>{ if(S.pinEdit) return; runCommand(name); };
497: /* ---------- command line (pipes) ---------- */
498: $('#cmdGo').onclick = runCmdLine;
499: $('#cmdInput').addEventListener('keydown',e=>{if(e.key==='Enter')runCmdLine();});
500: function runCmdLine(){
501:   const raw = $('#cmdInput').value.trim(); if(!raw) return;
502:   $('#cmdInput').value='';
503:   const stages = raw.split('|').map(s=>s.trim()).filter(Boolean);
504:   runPipeline(stages);
505: }
506: /* ---------- the engine ---------- */
507: async function runPipeline(stages){
508:   closeModal();
509:   let inputIds = [...S.selection];
510:   for(const stage of stages){
511:     const m = stage.match(/^(\w+)\s*(.*)$/); if(!m) continue;
512:     const cmd = m[1].toLowerCase();
513:     let arg = m[2].trim().replace(/^["']|["']$/g,'');
514:     const out = await execute(cmd, inputIds, arg);
515:     if(out===null) return;            // command opened a sheet / aborted
516:     inputIds = out;                   // pipe: output → next input
517:   }
518:   // final output becomes the live selection (ready to pipe further)
519:   S.selection = new Set(inputIds);
520:   render();
521:   if(inputIds.length) toast(`${inputIds.length} card${inputIds.length>1?'s':''} ready · open drawer to continue`);
522: }
523: function runCommand(name, ids){
524:   if(ids) S.selection = new Set(ids);
525:   runPipeline([name]);
526: }
527: async function execute(cmd, inputIds, arg){
528:   const inputs = inputIds.map(id=>S.cards.find(c=>c.id===id)).filter(Boolean);
529:   switch(cmd){
530:     case 'ask':    return await cmdAsk(arg, inputs);
531:     case 'source': return cmdSource(arg);
532:     case 'chunk':  return cmdChunk(inputs);
533:     case 'recall': return cmdRecall(inputs);
534:     case 'space':  return cmdSpace(inputs);
535:     case 'review': startReview(); return null;
536:     case 'move':   openMove(inputIds); return null;
537:     default: toast(`Unknown command: ${cmd}`); return null;
538:   }
539: }
540: function addCard(type, title, body, extra={}){
541:   const c = {id:uid(), ws:S.activeWs, type, title, body, created:now(), ...extra};
542:   S.cards.push(c); return c.id;
543: }
544: /* ---- ask: live agent w/ graceful fallback ---- */
545: async function cmdAsk(query, inputs){
546:   if(!query){ openAsk(); return null; }
547:   toast(`<span class="spinner"></span> asking the agent…`);
548:   let cards = await agentGenerate(query, inputs);
549:   const ids = cards.map(c=>addCard('chunk', c.title, c.body, {cite:c.cite||query.slice(0,18)}));
550:   render(); toast(`Agent returned ${ids.length} chunks`);
551:   return ids;
552: }
553: async function agentGenerate(query, inputs){
554:   const ctx = inputs.map(c=>c.body).join('\n').slice(0,1500);
555:   // try live model (works inside Claude); fall back to local generator
556:   try{
557:     const ctrl = new AbortController(); const to = setTimeout(()=>ctrl.abort(),14000);
558:     const r = await fetch("https://api.anthropic.com/v1/messages",{
559:       method:"POST", headers:{"Content-Type":"application/json"}, signal:ctrl.signal,
560:       body:JSON.stringify({
561:         model:"claude-sonnet-4-6", max_tokens:1000,
562:         messages:[{role:"user", content:
563:           `You generate atomic learning cards. Respond ONLY with a JSON array (no prose, no code fences) of 4 objects: {"title": string (max 6 words), "body": string (1-2 plain sentences, no markdown)}. Each card is one distinct, recall-ready idea.\n\nTopic: ${query}${ctx?`\n\nUse this source if relevant:\n${ctx}`:''}`}]
564:       })
565:     });
566:     clearTimeout(to);
567:     const data = await r.json();
568:     let text = (data.content||[]).map(b=>b.text||'').join('').trim();
569:     text = text.replace(/^```json|```$/g,'').replace(/```/g,'').trim();
570:     const arr = JSON.parse(text);
571:     if(Array.isArray(arr) && arr.length) return arr.slice(0,5).map(o=>({title:String(o.title||'Idea'),body:String(o.body||'')}));
572:   }catch(e){ /* fall through to local */ }
573:   return localChunks(query);
574: }
575: function localChunks(q){
576:   const t = q.replace(/^(how|what|why|explain|tell me about|the)\s+/i,'').replace(/\?$/,'').trim();
577:   const T = t.charAt(0).toUpperCase()+t.slice(1);
578:   return [
579:     {title:`Core idea`, body:`At its heart, ${t} is best understood as one central principle — name it in a single sentence before adding any detail.`},
580:     {title:`Why it matters`, body:`${T} matters because it changes what you can predict or do; tie it to a concrete outcome you care about.`},
581:     {title:`How it works`, body:`Break ${t} into the two or three moving parts that interact, and describe what each one does on its own.`},
582:     {title:`Common mistake`, body:`The usual error with ${t} is to confuse it with a surface-similar idea — note the one distinction that keeps them apart.`},
583:   ];
584: }
585: /* ---- source ---- */
586: function cmdSource(arg){
587:   if(!arg){ openSource(); return null; }
588:   const isUrl = /^https?:\/\//i.test(arg);
589:   const id = addCard('source', isUrl?arg.replace(/^https?:\/\//,'').slice(0,40):arg.slice(0,46), arg, {cite:'your source'});
590:   render(); toast('Source added'); return [id];
591: }
592: /* ---- chunk ---- */
593: function cmdChunk(inputs){
594:   const targets = inputs.filter(c=>c.type==='source'||c.type==='chunk'||c.type==='note');
595:   if(!targets.length){ toast('Select a source or note to chunk'); return []; }
596:   const ids=[];
597:   targets.forEach(c=>{
598:     const parts = c.body.split(/(?<=[.!?])\s+|\n+/).map(s=>s.trim()).filter(s=>s.length>12);
599:     const use = parts.length>1?parts:[c.body];
600:     use.slice(0,6).forEach((p,i)=>{
601:       ids.push(addCard('chunk', `${c.title.slice(0,30)} · ${i+1}`, p, {cite:c.cite}));
602:     });
603:   });
604:   render(); toast(`Chunked into ${ids.length} cards`); return ids;
605: }
606: /* ---- recall ---- */
607: function cmdRecall(inputs){
608:   const targets = inputs.filter(c=>c.type==='chunk'||c.type==='source'||c.type==='note');
609:   if(!targets.length){ toast('Select cards to turn into questions'); return []; }
610:   const ids = targets.map(c=>{
611:     const q = makeQuestion(c.body, c.title);
612:     return addCard('question', q, '', {answer:c.body, cite:c.cite});
613:   });
614:   render(); toast(`Made ${ids.length} recall question${ids.length>1?'s':''}`); return ids;
615: }
616: function makeQuestion(body, title){
617:   const s = body.trim();
618:   // light heuristic: prompt for the idea behind the statement
619:   const subj = title.replace(/·.*$/,'').trim();
620:   if(/because|matters/i.test(s)) return `Why does ${subj.toLowerCase()} matter?`;
621:   if(/break|parts|works/i.test(s)) return `How does ${subj.toLowerCase()} work?`;
622:   if(/mistake|confuse|error/i.test(s)) return `What\u2019s the common mistake with ${subj.toLowerCase()}?`;
623:   return `Recall: ${subj}`;
624: }
625: /* ---- space (FSRS-lite) ---- */
626: function cmdSpace(inputs){
627:   const targets = inputs.filter(c=>c.type==='question');
628:   if(!targets.length){ toast('Spacing needs question cards (run recall first)'); return []; }
629:   targets.forEach(c=>{ if(!c.schedule) c.schedule = {due: now()+DAY, interval:1, reps:0}; });
630:   render(); toast(`Scheduled ${targets.length} card${targets.length>1?'s':''} · first review tomorrow`);
631:   return targets.map(c=>c.id);
632: }
633: /* ---------- review flow ---------- */
634: window.startReview = ()=>{
635:   let q = dueCards();
636:   if(!q.length) q = wsCards().filter(c=>c.schedule);     // demo: allow early review
637:   if(!q.length){ toast('Nothing scheduled yet — run space first'); return; }
638:   S.reviewQueue = q; S.reviewIdx = 0;
639:   closeModal(); showReviewCard();
640:   $('#review').classList.add('show');
641: };
642: $('#revClose').onclick = ()=>{$('#review').classList.remove('show');render();};
643: function showReviewCard(){
644:   const c = S.reviewQueue[S.reviewIdx];
645:   if(!c){ endReview(); return; }
646:   $('#revProg').innerHTML = `<b>${S.reviewIdx+1}</b> / ${S.reviewQueue.length}`;
647:   $('#revQ').innerHTML = md(c.title);
648:   $('#revA').style.display='none'; $('#revA').innerHTML = md(c.answer)+(c.cite?` <span class="cite">◆ ${c.cite}</span>`:'');
649:   $('#revFoot').innerHTML = `<button class="reveal" id="revReveal">Reveal</button>`;
650:   $('#revReveal').onclick = reveal;
