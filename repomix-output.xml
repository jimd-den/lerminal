579:   }
580:   async restartOnboarding(): Promise<void> {
581:     const logTimestamp = new Date().toISOString();
582:     try {
583:       const workspaces = await this.workspaceRepo.getWorkspaces();
584:       for (const ws of workspaces) {
585:         const cards = await this.cardRepo.getCardsByWorkspace(ws.id);
586:         for (const card of cards) {
587:           await this.cardRepo.deleteCard(card.id);
588:         }
589:         await this.workspaceRepo.deleteWorkspace(ws.id);
590:       }
591:       this.state.workspaces = [];
592:       this.state.activeWorkspaceId = null;
593:       this.state.cards = [];
594:       this.state.selection.clear();
595:       this.state.onboarded = false;
596:       this.state.isOnboardingOpen = true;
597:       this.state.onboardingStep = 0;
598:       this.state.onboardingAnswers = [];
599:       this.emit();
600:       console.log(`[${logTimestamp}] [LearnimalController.restartOnboarding] SUCCESS`);
601:       this.showToast("Onboarding restarted");
602:     } catch (err: any) {
603:       console.error(`[${logTimestamp}] [LearnimalController.restartOnboarding] ERROR: ${err.message}`);
604:     }
605:   }
606:   private async loadCardsForActiveWorkspace(): Promise<void> {
607:     if (this.state.activeWorkspaceId) {
608:       const cards = await this.cardRepo.getCardsByWorkspace(this.state.activeWorkspaceId);
