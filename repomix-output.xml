675: function openSource(){inputMode='source';$('#inputTitle').textContent='Add a source';$('#inputSub').textContent='Paste text or a link. It becomes a card.';$('#inputText').placeholder='Paste an article, notes, or a URL…';$('#inputText').value='';openSheet('#inputSheet');setTimeout(()=>$('#inputText').focus(),300);}
