<file path="src/entities/commandDefinition.ts">
 1: export type CommandKind = "agent";
 2: interface BaseCommandDefinition {
 3:   id: string;
 4:   name: string;
 5:   description: string;
 6:   createdAt: number;
 7: }
 8: export interface AgentCommandDefinition extends BaseCommandDefinition {
 9:   kind: "agent";
10:   systemPrompt: string;
11: }
12: export type CommandDefinition = AgentCommandDefinition;
13: export const RESERVED_COMMAND_NAMES: readonly string[] = [
14:   "ask",
15:   "source",
16:   "chunk",
17:   "recall",
18:   "space",
19:   "review",
20:   "move",
21:   "group",
22:   "ungroup",
23:   "delete",
24: ];
25: export const COMMAND_NAME_PATTERN = /^[a-z][a-z0-9-]*$/;
26: export function normalizeCommandName(name: string): string {
27:   return name.trim().toLowerCase().replace(/\s+/g, "-");
28: }
29: export interface CreateCommandDefinitionParams {
30:   id?: string;
31:   name: string;
32:   description?: string;
33:   kind?: CommandKind;
34:   systemPrompt: string;
35:   createdAt?: number;
36: }
37: export function createCommandDefinition(params: CreateCommandDefinitionParams): CommandDefinition {
38:   const logTimestamp = new Date().toISOString();
39:   const definition: CommandDefinition = {
40:     id: params.id || Math.random().toString(36).substring(2, 10),
41:     name: normalizeCommandName(params.name),
42:     description: params.description?.trim() || "Custom agent command",
43:     kind: params.kind || "agent",
44:     systemPrompt: params.systemPrompt,
45:     createdAt: params.createdAt || Date.now(),
46:   };
47:   console.log(`[${logTimestamp}] [createCommandDefinition] OUTPUT: ${JSON.stringify({ ...definition, systemPrompt: `(${definition.systemPrompt.length} chars)` })}`);
48:   return definition;
49: }
</file>

<file path="src/frameworks/storage/AsyncStorageCommandDefinitionRepository.ts">
 1: import AsyncStorage from "@react-native-async-storage/async-storage";
 2: import { CommandDefinition } from "../../entities/commandDefinition";
 3: import { CommandDefinitionRepository } from "../../adapters/repositories/CommandDefinitionRepository";
 4: const COMMAND_DEFINITIONS_KEY = "learnimal_command_definitions_v1";
 5: export class AsyncStorageCommandDefinitionRepository implements CommandDefinitionRepository {
 6:   async getDefinitions(): Promise<CommandDefinition[]> {
 7:     const logTimestamp = new Date().toISOString();
 8:     try {
 9:       const data = await AsyncStorage.getItem(COMMAND_DEFINITIONS_KEY);
10:       if (!data) return [];
11:       const list = JSON.parse(data) as CommandDefinition[];
12:       console.log(`[${logTimestamp}] [AsyncStorageCommandDefinitionRepository.getDefinitions] -> retrieved ${list.length}`);
13:       return list;
14:     } catch (err: any) {
15:       console.error("[AsyncStorageCommandDefinitionRepository] Failed to read definitions:", err.message);
16:       return [];
17:     }
18:   }
19:   async saveDefinition(definition: CommandDefinition): Promise<void> {
20:     const logTimestamp = new Date().toISOString();
21:     try {
22:       const list = await this.getDefinitions();
23:       const index = list.findIndex(d => d.id === definition.id);
24:       if (index >= 0) list[index] = definition;
25:       else list.push(definition);
26:       await AsyncStorage.setItem(COMMAND_DEFINITIONS_KEY, JSON.stringify(list));
27:       console.log(`[${logTimestamp}] [AsyncStorageCommandDefinitionRepository.saveDefinition] id=${definition.id}`);
28:     } catch (err: any) {
29:       console.error("[AsyncStorageCommandDefinitionRepository] Failed to save definition:", err.message);
30:     }
31:   }
32:   async deleteDefinition(id: string): Promise<void> {
33:     const logTimestamp = new Date().toISOString();
34:     try {
35:       const list = await this.getDefinitions();
36:       await AsyncStorage.setItem(COMMAND_DEFINITIONS_KEY, JSON.stringify(list.filter(d => d.id !== id)));
37:       console.log(`[${logTimestamp}] [AsyncStorageCommandDefinitionRepository.deleteDefinition] id=${id}`);
38:     } catch (err: any) {
39:       console.error("[AsyncStorageCommandDefinitionRepository] Failed to delete definition:", err.message);
40:     }
41:   }
42: }
