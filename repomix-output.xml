357: <script>
358: "use strict";
359: /* ---------- state ---------- */
360: const uid = () => Math.random().toString(36).slice(2,8);
361: const now = () => Date.now();
362: const DAY = 86400000;
363: const ACCENTS = {
364:   teal:  {a:'#4EC7C0', s:'rgba(78,199,192,.14)', l:'rgba(78,199,192,.38)'},
365:   lilac: {a:'#B49CE6', s:'rgba(180,156,230,.16)', l:'rgba(180,156,230,.4)'},
366:   amber: {a:'#E0A45E', s:'rgba(224,164,94,.16)', l:'rgba(224,164,94,.4)'},
367:   rose:  {a:'#E8829B', s:'rgba(232,130,155,.16)', l:'rgba(232,130,155,.4)'},
368:   arctic:{a:'#7FB2E8', s:'rgba(127,178,232,.16)', l:'rgba(127,178,232,.4)'},
369: };
370: const COMMANDS = {
371:   ask:    {dot:'var(--c-chunk)',   desc:'Ask the agent · returns chunked cards', needs:'none'},
372:   source: {dot:'var(--c-source)',  desc:'Bring in text or a link',              needs:'none'},
373:   chunk:  {dot:'var(--c-chunk)',   desc:'Split into atomic cards',              needs:'cards'},
374:   recall: {dot:'var(--c-question)',desc:'Make active-recall questions',         needs:'cards'},
375:   space:  {dot:'var(--c-due)',     desc:'Schedule with spaced repetition',      needs:'questions'},
376:   review: {dot:'var(--c-due)',     desc:'Run today\u2019s due reviews',         needs:'none'},
377:   move:   {dot:'var(--c-source)',  desc:'Send cards to another workspace',      needs:'cards'},
378: };
379: let S = {
380:   theme:'dark', accent:'teal',
381:   workspaces:[], activeWs:null,
382:   cards:[],
383:   pinned:['ask','chunk','recall','space','review'],
384:   onboarded:false,
385:   selection:new Set(),
386:   openCard:null,
387:   reviewQueue:[], reviewIdx:0,
388:   pinEdit:false,
389: };
390: /* ---------- helpers ---------- */
391: const $ = s => document.querySelector(s);
392: const wsCards = () => S.cards.filter(c => c.ws === S.activeWs);
393: const dueCards = () => wsCards().filter(c => c.schedule && c.schedule.due <= now());
394: function toast(msg){const t=$('#toast');t.innerHTML=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2200);}
395: function md(t){return (t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/\*\*(.+?)\*\*/g,'<b>$1</b>').replace(/\n/g,'<br>');}
396: /* ---------- render canvas ---------- */
397: function render(){
398:   const wrap = $('#canvas');
399:   $('#wsName').textContent = S.workspaces.find(w=>w.id===S.activeWs)?.name || 'Workspace';
400:   const cards = wsCards();
401:   let html = '';
402:   const due = dueCards().length;
403:   if(due) html += `<div class="due-banner"><span class="dl">${due} card${due>1?'s':''} ready to review</span><button onclick="startReview()">Review</button></div>`;
404:   if(!cards.length){
405:     html += `<div class="empty"><h3>Empty canvas</h3><p>Open the drawer on the right and run <span class="mono">ask</span> — or pipe <span class="mono">ask | chunk | recall | space</span> to learn something end to end.</p></div>`;
406:   } else {
407:     cards.slice().reverse().forEach((c,i)=>{
408:       const sel = S.selection.has(c.id);
409:       const sched = c.schedule;
410:       let meta = '';
