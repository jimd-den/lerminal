652: function reveal(){
653:   $('#revA').style.display='block';
654:   $('#revFoot').innerHTML =
655:     `<button class="no" onclick="grade(false)">Not yet<span>~10 min</span></button>
656:      <button class="yes" onclick="grade(true)">Got it<span id="nextInt"></span></button>`;
657:   const c=S.reviewQueue[S.reviewIdx];
658:   const next=Math.round((c.schedule.interval||1)*2.4)+1;
659:   $('#nextInt').textContent = `+ ${next} days`;
660: }
661: window.grade = (ok)=>{
662:   const c=S.reviewQueue[S.reviewIdx];
663:   if(ok){ c.schedule.reps++; c.schedule.interval=Math.round((c.schedule.interval||1)*2.4)+1; c.schedule.due=now()+c.schedule.interval*DAY; }
664:   else { c.schedule.interval=1; c.schedule.due=now()+600000; }
665:   S.reviewIdx++; showReviewCard();
