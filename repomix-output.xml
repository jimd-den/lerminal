569:     const initialInputCards = expandForPipe(this.domain.cards, this.domain.selection);
570:     try {
571:       const outcome = await this.pipeline.run(pipelineText, {
572:         workspaceId,
573:         parentId: this.domain.currentGroupId,
574:         initialInputCards,
575:         workspaces: this.domain.workspaces,
576:         apiKey: this.domain.openRouterKey,
577:         model: this.domain.selectedModel,
578:         systemPrompt: this.domain.customSystemPrompt,
579:         autoGroup: this.domain.autoGroupByCommand,
580:       });
581:       if (outcome.kind === "needsInput") {
582:         this.ui.pendingCommandName = outcome.command;
583:         this.setInputSheetOpen(true, outcome.mode);
584:         return;
585:       }
586:       if (outcome.kind === "review") {
587:         this.startReview();
588:         return;
589:       }
590:       this.domain.selection = new Set(outcome.cards.map(c => c.id));
591:       await this.loadCardsForActiveWorkspace();
592:       if (outcome.cards.length > 0) {
593:         this.showToast(`${outcome.cards.length} cards ready. Open drawer to pipe.`);
594:       }
595:     } catch (err: any) {
596:       console.error(`[${logTimestamp}] [LearnimalController.runPipeline] ERROR: ${err.message}`);
597:       this.showToast(err instanceof UseCaseError ? err.userMessage : "Pipeline failed");
598:     }
599:   }
600:   startReview(): void {
601:     const logTimestamp = new Date().toISOString();
602:     try {
603:       const queue = this.startReviewInteractor.execute(this.domain.cards, Date.now());
604:       this.domain.reviewQueue = queue;
605:       this.domain.reviewIndex = 0;
606:       this.ui.isReviewOpen = true;
607:       this.ui.reviewRevealAnswer = false;
608:       this.emit();
609:       console.log(`[${logTimestamp}] [LearnimalController.startReview] Started review with ${queue.length} cards`);
610:     } catch (err: any) {
611:       console.log(`[${logTimestamp}] [LearnimalController.startReview] Halted: ${err.message}`);
612:       this.showToast(err instanceof UseCaseError ? err.userMessage : "Could not start review");
613:     }
614:   }
615:   revealReviewAnswer(): void {
616:     this.ui.reviewRevealAnswer = true;
617:     this.emit();
618:   }
619:   async gradeReview(ok: boolean): Promise<void> {
620:     const logTimestamp = new Date().toISOString();
621:     const currentCard = this.domain.reviewQueue[this.domain.reviewIndex];
622:     if (!currentCard) return;
623:     const updated = await this.gradeReviewInteractor.execute(currentCard, ok, Date.now());
624:     if (!updated) return;
625:     const nextIndex = this.domain.reviewIndex + 1;
626:     if (nextIndex >= this.domain.reviewQueue.length) {
627:       this.ui.isReviewOpen = false;
628:       this.domain.reviewQueue = [];
629:       this.domain.reviewIndex = 0;
630:       this.ui.reviewRevealAnswer = false;
631:       await this.loadCardsForActiveWorkspace();
632:       this.showToast("Review complete!");
633:       console.log(`[${logTimestamp}] [LearnimalController.gradeReview] Finished review session`);
634:     } else {
635:       this.domain.reviewIndex = nextIndex;
636:       this.ui.reviewRevealAnswer = false;
637:       this.emit();
638:     }
639:   }
640:   closeReview(): void {
641:     this.ui.isReviewOpen = false;
642:     this.domain.reviewQueue = [];
643:     this.domain.reviewIndex = 0;
644:     this.ui.reviewRevealAnswer = false;
645:     this.emit();
646:   }
647:   async loadAvailableModels(): Promise<void> {
648:     const logTimestamp = new Date().toISOString();
649:     this.ui.isLoadingModels = true;
650:     this.emit();
651:     try {
652:       this.domain.availableModels = await this.loadModelsInteractor.execute();
653:       console.log(`[${logTimestamp}] [LearnimalController.loadAvailableModels] SUCCESS | count=${this.domain.availableModels.length}`);
654:     } catch (err: any) {
655:       console.error(`[${logTimestamp}] [LearnimalController.loadAvailableModels] ERROR: ${err.message}`);
656:     } finally {
657:       this.ui.isLoadingModels = false;
658:       this.emit();
659:     }
660:   }
661:   async restartOnboarding(): Promise<void> {
662:     const logTimestamp = new Date().toISOString();
663:     try {
664:       await this.restartOnboardingInteractor.execute();
665:       this.domain.workspaces = [];
666:       this.domain.activeWorkspaceId = null;
667:       this.domain.currentGroupId = null;
668:       this.domain.cards = [];
669:       this.domain.selection.clear();
670:       this.domain.onboarded = false;
671:       this.ui.isOnboardingOpen = true;
672:       this.domain.onboardingStep = 0;
673:       this.domain.onboardingAnswers = [];
674:       this.emit();
675:       console.log(`[${logTimestamp}] [LearnimalController.restartOnboarding] SUCCESS`);
676:       this.showToast("Onboarding restarted");
677:     } catch (err: any) {
678:       console.error(`[${logTimestamp}] [LearnimalController.restartOnboarding] ERROR: ${err.message}`);
679:     }
680:   }
681:   private async loadCardsForActiveWorkspace(): Promise<void> {
682:     if (this.domain.activeWorkspaceId) {
683:       this.domain.cards = await this.cardRepo.getCardsByWorkspace(this.domain.activeWorkspaceId);
684:     } else {
685:       this.domain.cards = [];
686:     }
687:   }
688:   private showToast(message: string): void {
689:     this.ui.toastMessage = message;
690:     this.emit();
691:     setTimeout(() => {
692:       if (this.ui.toastMessage === message) {
693:         this.ui.toastMessage = "";
694:         this.emit();
695:       }
696:     }, 2500);
697:   }
698:   private emit(): void {
699:     const freshState = this.getState();
700:     for (const listener of this.listeners) {
701:       listener(freshState);
702:     }
703:   }
704: }
