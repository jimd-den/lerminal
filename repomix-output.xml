 3: import { directChildren } from "../tree";
 4: export class DeleteCardInteractor {
 5:   constructor(private readonly cardRepo: CardRepository) {}
 6:   async execute(card: Card): Promise<void> {
 7:     const siblingsAndChildren = await this.cardRepo.getCardsByWorkspace(card.workspaceId);
 8:     for (const child of directChildren(siblingsAndChildren, card.id)) {
 9:       await this.cardRepo.saveCard({ ...child, parentId: card.parentId });
10:     }
11:     await this.cardRepo.deleteCard(card.id);
12:   }
13: }
