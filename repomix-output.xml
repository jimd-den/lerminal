<file path="src/frameworks/ui/useControllerState.ts">
 1: import { useEffect, useState } from "react";
 2: import { AppState, LearnimalController } from "../../adapters/presenters/LearnimalController";
 3: export function useControllerState(controller: LearnimalController): AppState {
 4:   const [state, setState] = useState<AppState>(controller.getState());
 5:   useEffect(() => {
 6:     const unsubscribe = controller.subscribe((nextState) => {
 7:       setState(nextState);
 8:     });
 9:     return unsubscribe;
10:   }, [controller]);
11:   return state;
12: }
</file>

<file path="src/usecases/__tests__/commands.test.ts">
 1: import { describe, expect, it } from "bun:test";
 2: import { chunkCard, recallCard } from "../commands";
 3: import { createCard } from "../../entities/card";
 4: describe("Command Use Cases", () => {
 5:   it("should split a source card into multiple chunk cards based on sentences", () => {
 6:     const sourceCard = createCard({
 7:       workspaceId: "ws-1",
 8:       type: "source",
 9:       title: "Introduction to React",
10:       body: "React is a UI library. It is developed by Meta. You can build web apps with it.",
11:       cite: "reactjs.org",
12:     });
13:     const chunks = chunkCard(sourceCard);
14:     expect(chunks.length).toBe(3);
15:     expect(chunks[0].type).toBe("chunk");
16:     expect(chunks[0].title).toBe("Introduction to React · 1");
17:     expect(chunks[0].body).toBe("React is a UI library.");
18:     expect(chunks[0].cite).toBe("reactjs.org");
19:     expect(chunks[0].sourceRef).toBe(sourceCard.id);
20:     expect(chunks[1].body).toBe("It is developed by Meta.");
21:     expect(chunks[2].body).toBe("You can build web apps with it.");
22:   });
23:   it("should generate active recall questions from chunks", () => {
24:     const chunk1 = createCard({
25:       workspaceId: "ws-1",
26:       type: "chunk",
27:       title: "State Management",
28:       body: "State matters because it changes what you can render on screen.",
29:       cite: "React docs",
30:     });
31:     const question1 = recallCard(chunk1);
32:     expect(question1.type).toBe("question");
33:     expect(question1.title).toBe("Why does state management matter?");
34:     expect(question1.answer).toBe(chunk1.body);
35:     expect(question1.cite).toBe("React docs");
36:     const chunk2 = createCard({
37:       workspaceId: "ws-1",
38:       type: "chunk",
39:       title: "Redux Architecture",
40:       body: "Redux works by dispatching actions to a central store containing state.",
41:     });
42:     const question2 = recallCard(chunk2);
43:     expect(question2.title).toBe("How does redux architecture work?");
44:   });
