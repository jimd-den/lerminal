<file path="src/usecases/__tests__/tree.test.ts">
 1: import { describe, expect, it } from "bun:test";
 2: import { createCard } from "../../entities/card";
 3: import {
 4:   breadcrumbPath,
 5:   collectDescendants,
 6:   directChildren,
 7:   expandForPipe,
 8:   selectionRoots,
 9: } from "../tree";
10: const g1 = createCard({ id: "g1", workspaceId: "w", type: "group", title: "G1", body: "" });
11: const a = createCard({ id: "a", workspaceId: "w", type: "chunk", title: "A", body: "x", parentId: "g1" });
12: const g2 = createCard({ id: "g2", workspaceId: "w", type: "group", title: "G2", body: "", parentId: "g1" });
13: const b = createCard({ id: "b", workspaceId: "w", type: "chunk", title: "B", body: "y", parentId: "g2" });
14: const rootCard = createCard({ id: "r", workspaceId: "w", type: "note", title: "R", body: "z" });
15: const ALL = [g1, a, g2, b, rootCard];
16: describe("tree helpers", () => {
17:   it("directChildren returns immediate children only", () => {
18:     expect(directChildren(ALL, null).map(c => c.id).sort()).toEqual(["g1", "r"]);
19:     expect(directChildren(ALL, "g1").map(c => c.id).sort()).toEqual(["a", "g2"]);
20:   });
21:   it("collectDescendants walks the whole subtree", () => {
22:     expect(collectDescendants(ALL, "g1").map(c => c.id).sort()).toEqual(["a", "b", "g2"]);
23:     expect(collectDescendants(ALL, "g2").map(c => c.id)).toEqual(["b"]);
24:   });
25:   it("expandForPipe expands selected groups to their descendants", () => {
26:     const expanded = expandForPipe(ALL, ["g1"]).map(c => c.id).sort();
27:     expect(expanded).toEqual(["a", "b", "g1", "g2"]);
28:   });
29:   it("expandForPipe leaves non-group selections untouched", () => {
30:     expect(expandForPipe(ALL, ["a", "r"]).map(c => c.id).sort()).toEqual(["a", "r"]);
31:   });
32:   it("selectionRoots keeps only top nodes, preserving substructure", () => {
33:     expect(selectionRoots([g1, a, g2, b]).map(c => c.id)).toEqual(["g1"]);
34:     expect(selectionRoots([a, g2]).map(c => c.id).sort()).toEqual(["a", "g2"]);
35:   });
36:   it("breadcrumbPath returns root-to-node chain", () => {
37:     expect(breadcrumbPath(ALL, "g2").map(c => c.id)).toEqual(["g1", "g2"]);
38:     expect(breadcrumbPath(ALL, null)).toEqual([]);
39:   });
40: });
