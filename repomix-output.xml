691: window.doMove=(wid,ids)=>{ids.forEach(id=>{const c=S.cards.find(x=>x.id===id);if(c)c.ws=wid;});S.selection.clear();closeModal();buildWsSheetLater();render();toast('Moved');};
692: function buildWsSheetLater(){setTimeout(buildWsSheet,400);}
