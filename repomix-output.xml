21:     try {
22:       const workspaces = await this.getWorkspaces();
23:       const index = workspaces.findIndex(w => w.id === workspace.id);
24:       if (index >= 0) {
25:         workspaces[index] = workspace;
26:       } else {
27:         workspaces.push(workspace);
28:       }
29:       await AsyncStorage.setItem(WORKSPACES_STORAGE_KEY, JSON.stringify(workspaces));
30:       console.log(`[${logTimestamp}] [AsyncStorageWorkspaceRepository.saveWorkspace] workspaceId=${workspace.id}`);
31:     } catch (err: any) {
32:       console.error("[AsyncStorageWorkspaceRepository] Failed to write workspace to disk:", err.message);
33:     }
34:   }
35:   async deleteWorkspace(workspaceId: string): Promise<void> {
36:     const logTimestamp = new Date().toISOString();
37:     try {
38:       const workspaces = await this.getWorkspaces();
39:       const filtered = workspaces.filter(w => w.id !== workspaceId);
40:       await AsyncStorage.setItem(WORKSPACES_STORAGE_KEY, JSON.stringify(filtered));
41:       console.log(`[${logTimestamp}] [AsyncStorageWorkspaceRepository.deleteWorkspace] workspaceId=${workspaceId}`);
42:     } catch (err: any) {
43:       console.error("[AsyncStorageWorkspaceRepository] Failed to delete workspace on disk:", err.message);
44:     }
45:   }
46: }
