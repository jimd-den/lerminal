<file path="src/usecases/commands/CreateCommandDefinitionInteractor.ts">
 1: import {
 2:   CommandDefinition,
 3:   COMMAND_NAME_PATTERN,
 4:   createCommandDefinition,
 5:   normalizeCommandName,
 6:   RESERVED_COMMAND_NAMES,
 7: } from "../../entities/commandDefinition";
 8: import { CommandDefinitionRepository } from "../../adapters/repositories/CommandDefinitionRepository";
 9: import {
10:   DuplicateCommandNameError,
11:   InvalidCommandNameError,
12:   ReservedCommandNameError,
13: } from "../errors";
14: export interface CreateCommandDefinitionRequest {
15:   name: string;
16:   description?: string;
17:   systemPrompt: string;
18: }
19: export class CreateCommandDefinitionInteractor {
20:   constructor(private readonly repo: CommandDefinitionRepository) {}
21:   async execute(request: CreateCommandDefinitionRequest): Promise<CommandDefinition> {
22:     const name = normalizeCommandName(request.name);
23:     if (!COMMAND_NAME_PATTERN.test(name)) {
24:       throw new InvalidCommandNameError();
25:     }
26:     if (RESERVED_COMMAND_NAMES.includes(name)) {
27:       throw new ReservedCommandNameError(name);
28:     }
29:     const existing = await this.repo.getDefinitions();
30:     if (existing.some(d => d.name === name)) {
31:       throw new DuplicateCommandNameError(name);
32:     }
33:     const definition = createCommandDefinition({
34:       name,
35:       description: request.description,
36:       systemPrompt: request.systemPrompt,
37:       kind: "agent",
38:     });
39:     await this.repo.saveDefinition(definition);
40:     return definition;
41:   }
42: }
</file>

