309:   async answerOnboardingQuestion(answer: string): Promise<void> {
310:     const logTimestamp = new Date().toISOString();
311:     const cleanAnswer = answer.trim();
312:     this.domain.onboardingAnswers.push(cleanAnswer);
313:     const nextStep = this.domain.onboardingStep + 1;
314:     console.log(`[${logTimestamp}] [LearnimalController.answerOnboardingQuestion] step=${this.domain.onboardingStep} -> answer="${cleanAnswer}"`);
315:     if (nextStep >= 5) {
316:       await this.finishOnboarding();
317:     } else {
318:       this.domain.onboardingStep = nextStep;
319:       this.emit();
320:     }
321:   }
322:   async skipOnboarding(): Promise<void> {
323:     const logTimestamp = new Date().toISOString();
324:     console.log(`[${logTimestamp}] [LearnimalController.skipOnboarding] Skipping remaining onboarding steps.`);
325:     const defaults = [
326:       "",                  // Step 0: API Key (default empty if not entered)
327:       "My learning goal",
328:       "curiosity",
329:       "experiment",
330:       "basics",
331:     ];
332:     for (let i = 0; i < 5; i++) {
333:       if (this.domain.onboardingAnswers[i] === undefined || this.domain.onboardingAnswers[i] === "") {
334:         this.domain.onboardingAnswers[i] = defaults[i];
335:       }
336:     }
337:     await this.finishOnboarding();
338:   }
339:   private async finishOnboarding(): Promise<void> {
340:     const logTimestamp = new Date().toISOString();
341:     const answers = this.domain.onboardingAnswers;
342:     const topic = answers[1] || "My first topic";
343:     const apiKey = answers[0] || "";
344:     const prompt = answers[4] || answers[1];
345:     // Close onboarding immediately so the user sees the workspace being built.
346:     this.domain.openRouterKey = apiKey;
347:     this.domain.onboarded = true;
348:     this.ui.isOnboardingOpen = false;
349:     this.domain.selection.clear();
350:     this.showToast(`Creating "${topic.substring(0, 22)}"…`);
351:     try {
352:       const { workspace, cards } = await this.completeOnboardingInteractor.execute({
353:         topic,
354:         prompt,
355:         settings: this.currentSettings(),
356:       });
357:       this.domain.workspaces.push(workspace);
358:       this.domain.activeWorkspaceId = workspace.id;
359:       this.domain.currentGroupId = null;
360:       this.domain.selection = new Set(cards.map(c => c.id));
361:       await this.loadCardsForActiveWorkspace();
362:       this.showToast("First cards generated! Pipe into recall.");
363:       console.log(`[${logTimestamp}] [LearnimalController.finishOnboarding] SUCCESS | wsId=${workspace.id}`);
364:     } catch (err: any) {
365:       console.error(`[${logTimestamp}] [LearnimalController.finishOnboarding] ERROR: ${err.message}`);
366:       this.showToast(err instanceof UseCaseError ? err.userMessage : "Onboarding setup failed");
367:     }
368:   }
