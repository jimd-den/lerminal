355:   async runPipeline(pipelineText: string): Promise<void> {
356:     const logTimestamp = new Date().toISOString();
357:     console.log(`[${logTimestamp}] [LearnimalController.runPipeline] Running: "${pipelineText}"`);
358:     const stages = pipelineText.split("|").map(s => s.trim()).filter(Boolean);
359:     let activeInputIds = Array.from(this.state.selection);
360:     this.state.isModalOpen = false;
361:     this.state.isInputSheetOpen = false;
362:     this.emit();
363:     for (const stage of stages) {
364:       const match = stage.match(/^(\w+)\s*(.*)$/);
365:       if (!match) continue;
366:       const cmd = match[1].toLowerCase();
367:       const arg = match[2].trim().replace(/^["']|["']$/g, "");
368:       const outputIds = await this.executeSingleCommand(cmd, activeInputIds, arg);
369:       if (outputIds === null) {
370:         // Pipeline halted (e.g. command triggered a modal sheet requiring user entry)
371:         return;
372:       }
373:       activeInputIds = outputIds;
374:     }
375:     // Output of the final stage becomes the active selection, ready for the next pipe!
376:     this.state.selection = new Set(activeInputIds);
377:     await this.loadCardsForActiveWorkspace();
378:     if (activeInputIds.length > 0) {
379:       this.showToast(`${activeInputIds.length} cards ready. Open drawer to pipe.`);
380:     }
381:   }
382:   private async executeSingleCommand(
383:     cmd: string,
384:     inputIds: string[],
385:     arg?: string
386:   ): Promise<string[] | null> {
387:     const logTimestamp = new Date().toISOString();
388:     const currentWsId = this.state.activeWorkspaceId;
389:     if (!currentWsId) {
390:       this.showToast("Create a workspace first");
391:       return [];
392:     }
393:     const selectedCards = inputIds
394:       .map(id => this.state.cards.find(c => c.id === id))
395:       .filter((c): c is Card => !!c);
396:     switch (cmd) {
397:       case "ask": {
398:         if (!arg) {
399:           this.setInputSheetOpen(true, "ask");
400:           return null;
401:         }
402:         this.showToast("Asking agent...");
403:         const agentCards = await this.agentGateway.ask(
404:           arg,
405:           selectedCards,
406:           this.state.openRouterKey,
407:           this.state.selectedModel,
408:           this.state.customSystemPrompt
409:         );
410:         const newCards = agentCards.map(item => createCard({
411:           workspaceId: currentWsId,
412:           type: "chunk",
413:           title: item.title,
414:           body: item.body,
415:           cite: arg.substring(0, 16),
416:         }));
417:         await this.cardRepo.saveCards(newCards);
418:         return newCards.map(c => c.id);
419:       }
420:       case "source": {
421:         if (!arg) {
422:           this.setInputSheetOpen(true, "source");
423:           return null;
424:         }
425:         const isUrl = /^https?:\/\//i.test(arg);
426:         const title = isUrl ? arg.replace(/^https?:\/\//, "").substring(0, 40) : arg.substring(0, 40);
427:         const sourceCard = createCard({
428:           workspaceId: currentWsId,
429:           type: "source",
430:           title,
431:           body: arg,
432:           cite: "user source",
433:         });
434:         await this.cardRepo.saveCard(sourceCard);
435:         return [sourceCard.id];
436:       }
437:       case "chunk": {
438:         const sourceOrNotes = selectedCards.filter(c => c.type === "source" || c.type === "note" || c.type === "chunk");
439:         if (sourceOrNotes.length === 0) {
440:           this.showToast("Select source or note to chunk");
441:           return [];
442:         }
443:         const outCards: Card[] = [];
444:         for (const card of sourceOrNotes) {
445:           const chunks = chunkCard(card);
446:           outCards.push(...chunks);
447:         }
448:         await this.cardRepo.saveCards(outCards);
449:         return outCards.map(c => c.id);
450:       }
451:       case "recall": {
452:         const chunkableCards = selectedCards.filter(c => c.type === "chunk" || c.type === "source" || c.type === "note");
453:         if (chunkableCards.length === 0) {
454:           this.showToast("Select source, note or chunk to recall");
455:           return [];
456:         }
457:         const outCards: Card[] = chunkableCards.map(c => recallCard(c));
458:         await this.cardRepo.saveCards(outCards);
459:         return outCards.map(c => c.id);
460:       }
461:       case "space": {
462:         const questionCards = selectedCards.filter(c => c.type === "question");
463:         if (questionCards.length === 0) {
464:           this.showToast("Recall questions needed to schedule spacing");
465:           return [];
466:         }
467:         const updatedCards: Card[] = [];
468:         for (const card of questionCards) {
469:           const schedule = createInitialSchedule(Date.now());
470:           const updated = {
471:             ...card,
472:             schedule,
473:           };
474:           await this.cardRepo.saveCard(updated);
475:           updatedCards.push(updated);
476:         }
477:         this.showToast(`Scheduled ${updatedCards.length} cards`);
478:         return updatedCards.map(c => c.id);
479:       }
480:       case "review": {
481:         this.startReview();
482:         return null;
483:       }
484:       case "move": {
485:         if (!arg) {
486:           this.showToast("Provide a workspace name or ID to move cards to");
487:           return [];
488:         }
489:         const targetWs = this.state.workspaces.find(w => w.id === arg || w.name.toLowerCase() === arg.toLowerCase());
490:         if (!targetWs) {
491:           this.showToast("Target workspace not found");
492:           return [];
493:         }
494:         for (const card of selectedCards) {
495:           const updatedCard = { ...card, workspaceId: targetWs.id };
496:           await this.cardRepo.saveCard(updatedCard);
497:         }
498:         this.state.selection.clear();
499:         await this.loadCardsForActiveWorkspace();
500:         this.showToast(`Moved ${selectedCards.length} cards to ${targetWs.name}`);
501:         return [];
502:       }
503:       default:
504:         this.showToast(`Unknown command: ${cmd}`);
505:         return [];
506:     }
507:   }
508:   startReview(): void {
509:     const logTimestamp = new Date().toISOString();
510:     const nowMs = Date.now();
511:     let due = this.state.cards.filter(
512:       c => c.type === "question" && c.schedule && c.schedule.dueAt <= nowMs
513:     );
514:     if (due.length === 0) {
515:       due = this.state.cards.filter(c => c.type === "question" && c.schedule);
516:     }
517:     if (due.length === 0) {
518:       this.showToast("Nothing due. Run space on questions first.");
519:       console.log(`[${logTimestamp}] [LearnimalController.startReview] Halted: No scheduled cards`);
520:       return;
521:     }
522:     this.state.reviewQueue = due;
523:     this.state.reviewIndex = 0;
524:     this.state.isReviewOpen = true;
525:     this.state.reviewRevealAnswer = false;
526:     this.emit();
527:     console.log(`[${logTimestamp}] [LearnimalController.startReview] Started review with ${due.length} cards`);
528:   }
529:   revealReviewAnswer(): void {
530:     this.state.reviewRevealAnswer = true;
531:     this.emit();
532:   }
533:   async gradeReview(ok: boolean): Promise<void> {
534:     const logTimestamp = new Date().toISOString();
535:     const currentCard = this.state.reviewQueue[this.state.reviewIndex];
536:     if (!currentCard || !currentCard.schedule) return;
537:     const updatedSchedule = updateSchedule(currentCard.schedule, ok, Date.now());
538:     const updatedCard: Card = {
539:       ...currentCard,
540:       schedule: updatedSchedule,
541:     };
542:     await this.cardRepo.saveCard(updatedCard);
543:     const nextIndex = this.state.reviewIndex + 1;
544:     if (nextIndex >= this.state.reviewQueue.length) {
545:       this.state.isReviewOpen = false;
546:       this.state.reviewQueue = [];
547:       this.state.reviewIndex = 0;
548:       this.state.reviewRevealAnswer = false;
549:       await this.loadCardsForActiveWorkspace();
550:       this.showToast("Review complete!");
551:       console.log(`[${logTimestamp}] [LearnimalController.gradeReview] Finished review session`);
552:     } else {
553:       this.state.reviewIndex = nextIndex;
554:       this.state.reviewRevealAnswer = false;
555:       this.emit();
556:     }
557:   }
558:   closeReview(): void {
559:     this.state.isReviewOpen = false;
560:     this.state.reviewQueue = [];
561:     this.state.reviewIndex = 0;
562:     this.state.reviewRevealAnswer = false;
563:     this.emit();
564:   }
565:   async loadAvailableModels(): Promise<void> {
