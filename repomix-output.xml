686:   let html=`<div class="grab"></div><h2>Move ${ids.length} card${ids.length>1?'s':''}</h2><div class="sub">Pick a destination workspace.</div><div class="sheet-list">`;
687:   others.forEach(w=>html+=`<div class="sheet-item" onclick="doMove('${w.id}',${JSON.stringify(ids).replace(/"/g,'&quot;')})"><span class="si-dot"></span><span class="si-name">${w.name}</span></div>`);
