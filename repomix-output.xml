553: async function agentGenerate(query, inputs){
554:   const ctx = inputs.map(c=>c.body).join('\n').slice(0,1500);
555:   // try live model (works inside Claude); fall back to local generator
556:   try{
557:     const ctrl = new AbortController(); const to = setTimeout(()=>ctrl.abort(),14000);
558:     const r = await fetch("https://api.anthropic.com/v1/messages",{
559:       method:"POST", headers:{"Content-Type":"application/json"}, signal:ctrl.signal,
560:       body:JSON.stringify({
561:         model:"claude-sonnet-4-6", max_tokens:1000,
562:         messages:[{role:"user", content:
563:           `You generate atomic learning cards. Respond ONLY with a JSON array (no prose, no code fences) of 4 objects: {"title": string (max 6 words), "body": string (1-2 plain sentences, no markdown)}. Each card is one distinct, recall-ready idea.\n\nTopic: ${query}${ctx?`\n\nUse this source if relevant:\n${ctx}`:''}`}]
564:       })
565:     });
566:     clearTimeout(to);
567:     const data = await r.json();
568:     let text = (data.content||[]).map(b=>b.text||'').join('').trim();
569:     text = text.replace(/^```json|```$/g,'').replace(/```/g,'').trim();
570:     const arr = JSON.parse(text);
571:     if(Array.isArray(arr) && arr.length) return arr.slice(0,5).map(o=>({title:String(o.title||'Idea'),body:String(o.body||'')}));
572:   }catch(e){ /* fall through to local */ }
573:   return localChunks(query);
574: }
575: function localChunks(q){
576:   const t = q.replace(/^(how|what|why|explain|tell me about|the)\s+/i,'').replace(/\?$/,'').trim();
577:   const T = t.charAt(0).toUpperCase()+t.slice(1);
578:   return [
579:     {title:`Core idea`, body:`At its heart, ${t} is best understood as one central principle — name it in a single sentence before adding any detail.`},
580:     {title:`Why it matters`, body:`${T} matters because it changes what you can predict or do; tie it to a concrete outcome you care about.`},
581:     {title:`How it works`, body:`Break ${t} into the two or three moving parts that interact, and describe what each one does on its own.`},
582:     {title:`Common mistake`, body:`The usual error with ${t} is to confuse it with a surface-similar idea — note the one distinction that keeps them apart.`},
583:   ];
584: }
