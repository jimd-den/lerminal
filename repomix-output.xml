<file path="src/usecases/commands.ts">
 1: import { Card, createCard } from "../entities/card";
 2: export function makeQuestion(body: string, title: string): string {
 3:   const text = body.trim();
 4:   const subject = title.replace(/·.*$/, "").trim();
 5:   if (/because|matters/i.test(text)) {
 6:     return `Why does ${subject.toLowerCase()} matter?`;
 7:   }
 8:   if (/break|parts|works|by/i.test(text)) {
 9:     return `How does ${subject.toLowerCase()} work?`;
10:   }
11:   if (/mistake|confuse|error/i.test(text)) {
12:     return `What’s the common mistake with ${subject.toLowerCase()}?`;
13:   }
14:   return `Recall: ${subject}`;
15: }
16: /**
17:  * Chunks a long text card (source or note) into a collection of smaller cards.
18:  * Uses a sentence-splitting lookbehind regex to respect punctuation boundaries.
19:  *
20:  * @param card The source card to split.
21:  * @returns An array of generated chunk cards.
22:  */
23: export function chunkCard(card: Card): Card[] {
24:   const logTimestamp = new Date().toISOString();
25:   // Split by sentence endings (.?! followed by spaces) or line breaks
26:   const sentences = card.body
27:     .split(/(?<=[.!?])\s+|\n+/)
28:     .map(s => s.trim())
29:     .filter(s => s.length > 12); // Ignore very short fragments
30:   const itemsToCreate = sentences.length > 0 ? sentences : [card.body];
31:   // Limit to a maximum of 6 chunks per card for mobile visibility limits
32:   const results = itemsToCreate.slice(0, 6).map((paragraph, index) => {
33:     const parentTitle = card.title.substring(0, 30);
34:     return createCard({
35:       workspaceId: card.workspaceId,
36:       type: "chunk",
37:       title: `${parentTitle} · ${index + 1}`,
38:       body: paragraph,
39:       sourceRef: card.id,
40:       cite: card.cite,
41:     });
42:   });
43:   console.log(`[${logTimestamp}] [chunkCard] INPUT: cardId=${card.id} | OUTPUT: generated ${results.length} chunks`);
44:   return results;
45: }
46: export function recallCard(card: Card): Card {
47:   const logTimestamp = new Date().toISOString();
48:   const questionTitle = makeQuestion(card.body, card.title);
49:   const result = createCard({
50:     workspaceId: card.workspaceId,
51:     type: "question",
52:     title: questionTitle,
53:     body: "",
54:     answer: card.body,
55:     sourceRef: card.id,
56:     cite: card.cite,
57:   });
58:   console.log(`[${logTimestamp}] [recallCard] INPUT: cardId=${card.id} | OUTPUT: questionCardId=${result.id}`);
59:   return result;
60: }
</file>

