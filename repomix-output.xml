<file path="src/usecases/pipeline/UngroupCommand.ts">
 1: import { Card } from "../../entities/card";
 2: import { CardRepository } from "../../adapters/repositories/CardRepository";
 3: import { directChildren } from "../tree";
 4: import { CommandContext, CommandResult, PipelineCommand } from "./Command";
 5: export class UngroupCommand implements PipelineCommand {
 6:   readonly name = "ungroup";
 7:   constructor(private readonly cardRepo: CardRepository) {}
 8:   async execute(_arg: string, ctx: CommandContext): Promise<CommandResult> {
 9:     const groups = ctx.inputCards.filter(c => c.type === "group");
10:     if (groups.length === 0) {
11:       return { kind: "cards", cards: ctx.inputCards };
12:     }
13:     const allCards = await this.cardRepo.getCardsByWorkspace(ctx.workspaceId);
14:     const freed: Card[] = [];
15:     for (const group of groups) {
16:       for (const child of directChildren(allCards, group.id)) {
17:         const reparented = { ...child, parentId: group.parentId };
18:         await this.cardRepo.saveCard(reparented);
19:         freed.push(reparented);
20:       }
21:       await this.cardRepo.deleteCard(group.id);
22:     }
23:     const passthrough = ctx.inputCards.filter(c => c.type !== "group");
24:     return { kind: "cards", cards: [...passthrough, ...freed] };
25:   }
26: }
</file>

<file path="src/usecases/tree.ts">
 1: import { Card } from "../entities/card";
 2: function parentKey(card: Card): string | null {
 3:   return card.parentId ?? null;
 4: }
 5: export function directChildren(cards: Card[], parentId: string | null): Card[] {
 6:   return cards.filter(c => parentKey(c) === parentId);
 7: }
 8: export function collectDescendants(cards: Card[], groupId: string): Card[] {
 9:   const childrenByParent = new Map<string, Card[]>();
10:   for (const card of cards) {
11:     const key = parentKey(card);
12:     if (key === null) continue;
13:     const bucket = childrenByParent.get(key);
14:     if (bucket) bucket.push(card);
15:     else childrenByParent.set(key, [card]);
16:   }
17:   const result: Card[] = [];
18:   const seen = new Set<string>([groupId]);
19:   const stack = [groupId];
20:   while (stack.length > 0) {
21:     const current = stack.pop()!;
22:     for (const child of childrenByParent.get(current) ?? []) {
23:       if (seen.has(child.id)) continue;
24:       seen.add(child.id);
25:       result.push(child);
26:       stack.push(child.id);
27:     }
28:   }
29:   return result;
30: }
31: export function expandForPipe(cards: Card[], selectedIds: Iterable<string>): Card[] {
32:   const byId = new Map(cards.map(c => [c.id, c]));
33:   const out: Card[] = [];
34:   const seen = new Set<string>();
35:   const push = (card: Card) => {
36:     if (seen.has(card.id)) return;
37:     seen.add(card.id);
38:     out.push(card);
39:   };
40:   for (const id of selectedIds) {
41:     const card = byId.get(id);
42:     if (!card) continue;
43:     push(card);
44:     if (card.type === "group") {
45:       for (const descendant of collectDescendants(cards, card.id)) {
46:         push(descendant);
47:       }
48:     }
49:   }
50:   return out;
51: }
52: export function selectionRoots(cards: Card[]): Card[] {
53:   const ids = new Set(cards.map(c => c.id));
54:   return cards.filter(c => {
55:     const key = parentKey(c);
56:     return key === null || !ids.has(key);
57:   });
58: }
59: export function breadcrumbPath(cards: Card[], groupId: string | null): Card[] {
60:   if (groupId === null) return [];
61:   const byId = new Map(cards.map(c => [c.id, c]));
62:   const path: Card[] = [];
63:   const seen = new Set<string>();
64:   let current: string | null = groupId;
65:   while (current !== null && !seen.has(current)) {
66:     seen.add(current);
67:     const card = byId.get(current);
68:     if (!card) break;
69:     path.unshift(card);
70:     current = card.parentId ?? null;
71:   }
72:   return path;
73: }
</file>

