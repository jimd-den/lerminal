<file path="src/usecases/review/StartReviewInteractor.ts">
 1: import { Card } from "../../entities/card";
 2: import { NothingDueError } from "../errors";
 3: export class StartReviewInteractor {
 4:   execute(cards: Card[], now: number): Card[] {
 5:     let due = cards.filter(
 6:       c => c.type === "question" && c.schedule && c.schedule.dueAt <= now
 7:     );
 8:     if (due.length === 0) {
 9:       due = cards.filter(c => c.type === "question" && c.schedule);
10:     }
11:     if (due.length === 0) {
12:       throw new NothingDueError();
13:     }
14:     return due;
15:   }
16: }
