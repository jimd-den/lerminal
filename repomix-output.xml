 2: import { Workspace } from "../../entities/workspace";
 3: import { UnknownCommandError } from "../errors";
 4: import { CommandContext, PipelineCommand } from "./Command";
 5: export interface PipelineEnvironment {
 6:   workspaceId: string;
 7:   parentId: string | null;
 8:   initialInputCards: Card[];
 9:   workspaces: Workspace[];
10:   apiKey: string;
11:   model: string;
12:   systemPrompt: string;
13:   autoGroup: boolean;
14: }
15: const AUTO_GROUP_PRODUCERS = new Set(["ask", "source", "chunk", "recall"]);
16: interface ParsedStage {
17:   cmd: string;
18:   arg: string;
19: }
20: export type PipelineOutcome =
21:   | { kind: "completed"; cards: Card[] }
22:   | { kind: "needsInput"; mode: "ask" | "source"; command: string }
23:   | { kind: "review" };
24: export class PipelineRunner {
25:   private readonly commands: Map<string, PipelineCommand>;
26:   constructor(commands: PipelineCommand[]) {
27:     this.commands = new Map(commands.map(c => [c.name, c]));
28:   }
29:   async run(pipelineText: string, env: PipelineEnvironment): Promise<PipelineOutcome> {
30:     const stages = this.withAutoGroup(this.parse(pipelineText), env.autoGroup);
31:     let cards = env.initialInputCards;
32:     for (const { cmd, arg } of stages) {
33:       const command = this.commands.get(cmd);
34:       if (!command) {
35:         throw new UnknownCommandError(cmd);
36:       }
37:       const ctx: CommandContext = {
38:         workspaceId: env.workspaceId,
39:         parentId: env.parentId,
40:         inputCards: cards,
41:         workspaces: env.workspaces,
42:         apiKey: env.apiKey,
43:         model: env.model,
44:         systemPrompt: env.systemPrompt,
45:       };
46:       const result = await command.execute(arg, ctx);
47:       if (result.kind === "needsInput") {
48:         return { kind: "needsInput", mode: result.mode, command: cmd };
49:       }
50:       if (result.kind === "review") {
51:         return { kind: "review" };
52:       }
53:       cards = result.kind === "cards" ? result.cards : [];
54:     }
55:     return { kind: "completed", cards };
56:   }
57:   private parse(pipelineText: string): ParsedStage[] {
58:     const stages: ParsedStage[] = [];
59:     for (const raw of pipelineText.split("|").map(s => s.trim()).filter(Boolean)) {
60:       const match = raw.match(/^(\w+)\s*(.*)$/);
61:       if (!match) continue;
62:       stages.push({
63:         cmd: match[1].toLowerCase(),
64:         arg: match[2].trim().replace(/^["']|["']$/g, ""),
65:       });
66:     }
67:     return stages;
68:   }
69:   /**
70:    * Auto-grouping is implemented as pure composition: when enabled and the pipeline
71:    * ends in a content-producing command (and isn't already a grouping command), a
72:    * trailing `group "<command>"` stage is appended so the run's output is organized
73:    * under a group named after the command that produced it.
74:    */
75:   private withAutoGroup(stages: ParsedStage[], autoGroup: boolean): ParsedStage[] {
76:     if (!autoGroup || stages.length === 0) return stages;
77:     const last = stages[stages.length - 1];
78:     if (!AUTO_GROUP_PRODUCERS.has(last.cmd)) return stages;
79:     return [...stages, { cmd: "group", arg: last.cmd }];
80:   }
81: }
</file>

