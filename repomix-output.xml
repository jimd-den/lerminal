 1: export interface ScheduleState {
 2:   dueAt: number;
 3:   interval: number;
 4:   reps: number;
 5: }
 6: export function createInitialSchedule(now: number): ScheduleState {
 7:   const logTimestamp = new Date().toISOString();
 8:   const result: ScheduleState = {
 9:     dueAt: now + 86400000,
10:     interval: 1,
11:     reps: 0,
12:   };
13:   console.log(`[${logTimestamp}] [createInitialSchedule] INPUTS: now=${now} | OUTPUT: ${JSON.stringify(result)}`);
14:   return result;
15: }
16: export function updateSchedule(current: ScheduleState, ok: boolean, now: number): ScheduleState {
17:   const logTimestamp = new Date().toISOString();
18:   let result: ScheduleState;
19:   if (ok) {
20:     const nextInterval = Math.round(current.interval * 2.4) + 1;
21:     result = {
22:       dueAt: now + nextInterval * 86400000,
23:       interval: nextInterval,
24:       reps: current.reps + 1,
25:     };
26:   } else {
27:     result = {
28:       dueAt: now + 600000,
29:       interval: 1,
30:       reps: current.reps,
31:     };
32:   }
33:   console.log(`[${logTimestamp}] [updateSchedule] INPUTS: current=${JSON.stringify(current)}, ok=${ok}, now=${now} | OUTPUT: ${JSON.stringify(result)}`);
34:   return result;
35: }
